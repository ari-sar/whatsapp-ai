generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String   @id @default(uuid())
  shop_name       String
  phone_number_id String   @unique
  access_token    String?
  plan            String   @default("free")

  keywords        Keyword[]
  leads           Lead[]
  user            User?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Response {
  id         String   @id @default(uuid())
  message    String
  media_url  String?

  keywords   Keyword[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Keyword {
  id          String   @id @default(uuid())
  client_id   String
  trigger     String
  response_id String?
  flow_id     String?

  client      Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  response    Response? @relation(fields: [response_id], references: [id], onDelete: Cascade)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([client_id, trigger])
}

model Lead {
  id              String   @id @default(uuid())
  client_id       String
  user_phone      String
  last_message    String
  timestamp       DateTime @default(now())

  current_flow_id String?
  current_step    String?
  collected_data  Json     @default("{}")

  client          Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([client_id, user_phone])
}

model User {
  id               String   @id @default(uuid())
  phone            String   @unique
  name             String?
  business_name    String?
  business_type_id String?
  plan_id          String?
  plan_started_at  DateTime?
  plan_expires_at  DateTime?
  is_onboarded     Boolean  @default(false)
  client_id        String?  @unique

  client           Client?  @relation(fields: [client_id], references: [id])
  keywords         UserKeyword[]
  payment_orders   PaymentOrder[]

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model OtpRequest {
  id         String   @id @default(uuid())
  phone      String
  code_hash  String
  expires_at DateTime
  consumed   Boolean  @default(false)
  attempts   Int      @default(0)
  created_at DateTime @default(now())

  @@index([phone, created_at])
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  price_in_paise  Int
  currency        String   @default("INR")
  billing_cycle   String
  duration_days   Int?
  description     String?
  discount_amount Int?
  discount_days   Int?
  features        String[]
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model BusinessFlow {
  id              String     @id
  business_type   String
  name            String
  description     String
  step_count      Int
  initial_step_id String?
  is_active       Boolean    @default(true)
  steps           FlowStep[]
  created_at      DateTime   @default(now())
  updated_at      DateTime   @default(now()) @updatedAt
}

model FlowStep {
  id          String       @id @default(uuid())
  flow_id     String
  step_id     String
  type        String
  config      Json         @default("{}")
  transitions Json         @default("[]")
  position_x  Float        @default(0)
  position_y  Float        @default(0)
  flow        BusinessFlow @relation(fields: [flow_id], references: [id], onDelete: Cascade)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@unique([flow_id, step_id])
}

model AdminPhone {
  id         String         @id @default(uuid())
  phone      String         @unique
  name       String?
  is_active  Boolean        @default(true)
  sessions   AdminSession[]
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
}

model AdminOtpRequest {
  id         String   @id @default(uuid())
  phone      String
  code_hash  String
  expires_at DateTime
  consumed   Boolean  @default(false)
  attempts   Int      @default(0)
  created_at DateTime @default(now())

  @@index([phone, created_at])
}

model AdminSession {
  id              String     @id @default(uuid())
  token           String     @unique
  admin_phone_id  String
  expires_at      DateTime
  last_seen_at    DateTime   @default(now())
  admin_phone     AdminPhone @relation(fields: [admin_phone_id], references: [id], onDelete: Cascade)
  created_at      DateTime   @default(now())

  @@index([admin_phone_id])
}

model UserKeyword {
  id               String   @id @default(uuid())
  user_id          String
  trigger          String
  response_message String
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([user_id, trigger])
}

model PaymentOrder {
  id                  String   @id @default(uuid())
  user_id             String
  plan_id             String
  razorpay_order_id   String   @unique
  amount              Int
  currency            String
  status              String
  razorpay_payment_id String?
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}
